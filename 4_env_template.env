# ─────────────────────────────────────────────────────────────
# Athena AI Agent — Environment Variables
# Copy this file to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────

# ── Google Cloud ──────────────────────────────────────────────
# Path to your GCP service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# Google Calendar ID (usually the firm's Gmail address)
GOOGLE_CALENDAR_ID=yourfirm@gmail.com

# Google Sheet ID (from the URL: /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Twilio ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+35725000000

# Fallback number to notify if no specific employee is matched
TWILIO_DEFAULT_NOTIFY_NUMBER=+35799000000

# ── Security ──────────────────────────────────────────────────
# Set this in ElevenLabs webhook headers as x-webhook-secret
WEBHOOK_SECRET=your_strong_random_secret_here

# ── Employee Directory ────────────────────────────────────────
# JSON mapping of names/roles (lowercase) to phone numbers
# Add all lawyers and staff who can receive forwarded calls
EMPLOYEE_DIRECTORY={"john smith":"+35799000001","maria kyriacou":"+35799000002","senior partner":"+35799000002","junior associate":"+35799000003","reception":"+35799000004","office manager":"+35799000004"}

# ── Server ────────────────────────────────────────────────────
PORT=3000
